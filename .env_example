# OpenRouter API key (used for LLM and embeddings)
OPENAI_API_KEY=""

# Embedding model (OpenRouter)
EMBEDDING_MODEL="openai/text-embedding-3-small"

# Neo4j connection settings
NEO4J_URI="bolt://localhost:7687"
NEO4J_USER="neo4j"
NEO4J_PASSWORD="password"

# ChromaDB persistence (optional, leave empty for in-memory)
CHROMA_PERSIST_DIR=""
